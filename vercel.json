{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "github": {
    "silent": true,
    "autoAlias": true
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
} 