{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "@vite_api_url",
    "VITE_STRIPE_PUBLIC_KEY": "@vite_stripe_public_key"
  },
  "github": {
    "silent": true,
    "autoAlias": true
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
} 