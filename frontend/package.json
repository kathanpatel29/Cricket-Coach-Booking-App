    "@mui/icons-material": "^5.15.11",
    "@mui/material": "^5.16.14",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "axios": "^1.6.7",
    "glob": "^11.0.1",
    "lru-cache": "^11.0.2",
    "react": "^18.2.0",
    "react-calendar": "^5.1.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.1",
    "react-redux": "^9.2.0",
