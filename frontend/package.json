{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "vercel-build": "vite build",
    "deploy": "vercel --prod",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testMatch='**/__tests__/unit/**/*.test.js' --coverage",
    "test:integration": "jest --testMatch='**/__tests__/integration/**/*.test.js' --coverage",
    "test:ci": "jest --ci --coverage --forceExit --detectOpenHandles",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:ci": "cypress run --browser chrome --headless"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
